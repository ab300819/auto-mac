{
  "name": "auto-mac",
  "displayName": "Auto Mac",
  "description": "macOS automation — Markdown to Mail.app draft & Apple Notes",
  "version": "0.5.0",
  "publisher": "auto-mac",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auto-mac.draft",
        "title": "Auto Mac: Send to Mail.app Draft",
        "icon": "$(mail)"
      },
      {
        "command": "auto-mac.dryRun",
        "title": "Auto Mac: Dry Run (Show Parsed Result)"
      },
      {
        "command": "auto-mac.preview",
        "title": "Auto Mac: Preview Email"
      },
      {
        "command": "auto-mac.notesCreate",
        "title": "Auto Mac: Send to Apple Notes",
        "icon": "$(notebook)"
      },
      {
        "command": "auto-mac.notesImport",
        "title": "Auto Mac: Import from Apple Notes",
        "icon": "$(cloud-download)"
      }
    ],
    "configuration": {
      "title": "Auto Mac",
      "properties": {
        "auto-mac.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to auto-mac CLI binary. Leave empty for auto-detection."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "prepackage": "npm run build",
    "package": "vsce package --no-dependencies --skip-license --baseContentUrl https://github.com/anthropics/auto-mac/tree/main/vscode"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
